{
  "packageId": "app.incipit.reader",
  "host": "incipit-navy.vercel.app",
  "name": "Incipit",
  "launcherName": "Incipit",
  "display": "standalone",
  "themeColor": "#1A1A2E",
  "navigationColor": "#1A1A2E",
  "navigationColorDark": "#0F0F1A",
  "navigationDividerColor": "#FAF7F0",
  "navigationDividerColorDark": "#0F0F1A",
  "backgroundColor": "#FAF7F0",
  "enableNotifications": true,
  "startUrl": "/",
  "iconUrl": "https://incipit-navy.vercel.app/icon-512.png",
  "maskableIconUrl": "https://incipit-navy.vercel.app/icon-maskable-512.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "./android-keystore.jks",
    "alias": "incipit"
  },
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "shortcuts": [
    {
      "name": "Quiz du jour",
      "shortName": "Quiz",
