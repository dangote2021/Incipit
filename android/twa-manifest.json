      "chosenIconUrl": "https://incipit-navy.vercel.app/icon-192.png"
    },
    {
      "name": "Incipit du jour",
      "shortName": "Incipit",
      "url": "/incipit-du-jour",
      "chosenIconUrl": "https://incipit-navy.vercel.app/icon-192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://incipit-navy.vercel.app/manifest.json",
  "fallbackType": "customtabs",
  "features": {
    "locationDelegation": { "enabled": false },
    "playBilling": { "enabled": false }
  },
  "alphaDependencies": { "enabled": false },
  "enableSiteSettingsShortcut": true,
  "isChromeOSOnly": false,
  "isMetaQuest": false,
  "fullScopeUrl": "https://incipit-navy.vercel.app/",
  "minSdkVersion": 23,
  "orientation": "portrait"
