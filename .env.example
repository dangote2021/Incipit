# ─────────────────────────────────────────────────────────────────────────────
# Incipit — variables d'environnement
#
# Toutes les variables sont OPTIONNELLES. Si une section n'est pas remplie,
# l'app tombe gracieusement sur le comportement localStorage V1 :
#   - pas de Supabase → pas de sync cross-device, favoris/streak/premium
#     restent en localStorage (comme aujourd'hui).
#   - pas de Stripe → le CTA premium affiche "bientôt" au lieu de crasher.
#   - pas de VAPID → le push notif est désactivé côté serveur.
#
# Copie ce fichier en `.env.local` pour dev, et définis les mêmes clés dans
# Vercel pour la prod.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (auth + DB) ────────────────────────────────────────────────────
# Crée un projet gratuit sur https://supabase.com/dashboard, puis applique
# les migrations du dossier `supabase/migrations/` (psql ou supabase CLI).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role (JAMAIS exposée côté client — uniquement routes /api et cron)
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (paiement Premium) ───────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# ID du Price Stripe (récurrent mensuel). Crée un Product "Incipit Premium"
# puis un Price mensuel, copie l'ID price_XXX ici.
NEXT_PUBLIC_STRIPE_PRICE_ID=
# URL publique de l'app pour les redirects Checkout
NEXT_PUBLIC_SITE_URL=https://incipit.vercel.app

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Génère une paire de clés avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Email de contact pour le sujet VAPID (RGPD)
VAPID_SUBJECT=mailto:contact@incipit.app

# ── Cron (Vercel) ───────────────────────────────────────────────────────────
# Secret partagé entre vercel.json (header Authorization) et /api/cron/*.
# Génère avec : openssl rand -base64 32
CRON_SECRET=
